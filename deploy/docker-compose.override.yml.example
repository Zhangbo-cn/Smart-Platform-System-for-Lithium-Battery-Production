# 本地开发 Docker Compose 覆盖配置
# 复制为 docker-compose.override.yml 使用
# 用法: docker compose -f deploy/docker-compose.platform.yml up -d

version: "3.9"

services:
  # 本地开发时映射源码目录，实现热重载
  rca-agent:
    volumes:
      - ../services/a2a_server/rca-agent:/app/services/a2a_server/rca-agent
    environment:
      - LOG_LEVEL=DEBUG
      - LANGGRAPH_CHECKPOINT_BACKEND=memory

  orchestrator:
    environment:
      - LOG_LEVEL=DEBUG
      - ENABLE_SMART_ROUTING=false

  client-gateway:
    environment:
      - LOG_LEVEL=DEBUG

  # MCP 服务器本地开发
  mcp-mes:
    volumes:
      - ../services/mcp/mes_server:/app/services/mcp/mes_server

  mcp-knowledge:
    environment:
      - LOG_LEVEL=DEBUG
    volumes:
      - ../services/mcp/knowledge_server:/app/services/mcp/knowledge_server
