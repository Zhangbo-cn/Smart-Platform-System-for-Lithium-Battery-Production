# Planner Agent
PLANNER_MODE=react
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-deepseek-key
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
MAX_REACT_TURNS=8

# LangSmith 追踪（环境变量方式，LangChain/LangGraph 自动读取）
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-key-placeholder
LANGSMITH_PROJECT=my_fir_app
