# LLM（DeepSeek 示例：OpenAI 兼容接口）
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_PRIMARY_MODEL=deepseek-chat
# 若用 Claude，留空 LLM_BASE_URL，改填 ANTHROPIC_API_KEY + claude 模型名
# ANTHROPIC_API_KEY=sk-ant-xxx
LLM_FALLBACK_MODEL=qwen2.5-72b-instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Local fallback LLM (vLLM / Ollama)
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_API_KEY=EMPTY

# Memory: Short-term (Redis)
REDIS_URL=redis://localhost:6379/0
SHORT_TERM_TTL_SECONDS=1800

# Memory: Working (PostgreSQL)
POSTGRES_DSN=postgresql+asyncpg://battery:battery@localhost:5432/battery_agent

# Memory: Long-term (Milvus + Neo4j)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=battery_cases
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j

# MCP Servers
MCP_MES_URL=http://localhost:8101/sse
MCP_SCADA_URL=http://localhost:8102/sse
MCP_ERP_URL=http://localhost:8103/sse
MCP_LIMS_URL=http://localhost:8104/sse

# Data sources (used by MCP Servers)
MES_DB_DSN=mysql+aiomysql://mes:mes@localhost:3306/mes
SCADA_INFLUX_URL=http://localhost:8086
SCADA_INFLUX_TOKEN=xxx
SCADA_INFLUX_ORG=battery
SCADA_INFLUX_BUCKET=process

# Auth
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=battery-agent

# App
APP_ENV=dev
LOG_LEVEL=INFO
API_PORT=8003
HITL_CONFIDENCE_THRESHOLD=0.7
MAX_REFLECTION_LOOPS=3

# Router 服务间调用（生产必须覆盖；APP_ENV=prod 时禁止 dev-router-key）
INTERNAL_SERVICE_KEY=dev-router-key

# LangGraph HITL checkpoint：memory（默认）| redis（生产推荐）
# pip install -e services/rca-agent[redis-checkpoint]
LANGGRAPH_CHECKPOINT_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
