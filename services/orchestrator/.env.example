# Orchestrator
TRACE_WORKER_URL=http://127.0.0.1:8002
RCA_AGENT_URL=http://127.0.0.1:8003
REPORT_8D_WORKER_URL=http://127.0.0.1:8004
REGISTRY_URL=http://127.0.0.1:8021
INTERNAL_SERVICE_KEY=dev-router-key

# Session 黑板 + SSE 事件总线（多实例请用 redis）
CONTEXT_BACKEND=memory
EVENT_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CONTEXT_TTL_SECONDS=86400
SSE_HEARTBEAT_INTERVAL=15

# 智能路由（默认关闭；开启后每步调 agent 前问 LLM）
# ENABLE_SMART_ROUTING=true
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# LangSmith 追踪
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-key-placeholder
LANGSMITH_PROJECT=my_fir_app
